# ---------------------------------------------------------------------------
# globlejump backend — environment configuration
# Copy to `.env` and adjust. Never commit a real .env.
# ---------------------------------------------------------------------------

# Runtime
ENVIRONMENT=local            # local | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false               # true => JSON logs (prod), false => console (dev)

# API
PROJECT_NAME="GlobleJump API"
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Database (async, asyncpg). Either set DATABASE_URL directly...
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app_db
# ...or set the discrete parts below (used to build the DSN if DATABASE_URL is unset):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# Auth — tokens issued BY this service
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ISSUER=globlejump
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Auth — token lifetimes
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# Auth — trust for tokens issued by the external identity-service.
# Provide a shared HS256 secret OR a JWKS URL (RS256). Leave blank to disable external trust.
IDENTITY_JWT_SECRET=
IDENTITY_JWKS_URL=
IDENTITY_ISSUER=identity-service
IDENTITY_AUDIENCE=globlejump

# Email (transactional — leave blank to disable sending, tokens are logged instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@globlejump.io
EMAILS_FROM_NAME=GlobleJump
FRONTEND_URL=http://localhost:3000

# File storage — S3 (leave blank to fall back to local disk storage under UPLOAD_DIR)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# OpenAI (AI assessment insights — leave key blank to disable; assessments still complete)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=20

# Observability (all optional — left blank => disabled)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=globlejump
